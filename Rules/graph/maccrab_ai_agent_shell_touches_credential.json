{
  "id": "maccrab_ai_agent_shell_touches_credential",
  "title": "AI agent's shell touched a credential file",
  "severity": "high",
  "type": "graph",
  "nodes": {
    "agent": { "type": "ai_agent" },
    "shell": {
      "type": "process",
      "where": {
        "executable_name": { "in": ["zsh", "bash", "sh", "osascript"] }
      }
    },
    "cred": {
      "type": "file",
      "where": { "file_kind": { "equals": "credential_file" } }
    }
  },
  "edges": [
    { "from": "agent", "to": "shell", "relation": "associated_with_agent", "min_tier": "weak_inferred" },
    { "from": "shell", "to": "cred",  "relation": "read",                  "min_tier": "weak_inferred" }
  ],
  "scope": { "common_ancestor": "agent", "max_depth": 4 },
  "constraints": { "within_seconds": 300, "min_confidence": 0.7 },
  "attack": ["T1059", "T1555"]
}
