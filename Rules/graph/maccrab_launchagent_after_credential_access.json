{
  "id": "maccrab_launchagent_after_credential_access",
  "title": "Persistence created shortly after credential access",
  "severity": "high",
  "type": "graph",
  "nodes": {
    "proc":    { "type": "process" },
    "cred":    { "type": "file",        "where": { "file_kind": { "equals": "credential_file" } } },
    "persist": { "type": "persistence", "where": { "persistence_type": { "in": ["launch_agent", "launch_daemon", "login_item"] } } }
  },
  "edges": [
    { "from": "proc", "to": "cred",    "relation": "read",                 "min_tier": "weak_inferred" },
    { "from": "proc", "to": "persist", "relation": "created_persistence",  "min_tier": "strong_inferred" }
  ],
  "scope": { "common_ancestor": "proc" },
  "constraints": { "within_seconds": 600, "min_confidence": 0.7 },
  "attack": ["T1543.001", "T1555"]
}
