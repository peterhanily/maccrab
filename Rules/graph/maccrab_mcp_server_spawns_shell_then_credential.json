{
  "id": "maccrab_mcp_server_spawns_shell_then_credential",
  "title": "MCP server spawned a shell that touched a credential file",
  "severity": "high",
  "type": "graph",
  "nodes": {
    "mcp": { "type": "mcp_server" },
    "shell": {
      "type": "process",
      "where": {
        "executable_name": { "in": ["zsh", "bash", "sh", "osascript"] }
      }
    },
    "cred": {
      "type": "file",
      "where": { "file_kind": { "equals": "credential_file" } }
    }
  },
  "edges": [
    { "from": "mcp",   "to": "shell", "relation": "spawned",              "min_tier": "weak_inferred" },
    { "from": "shell", "to": "cred",  "relation": "read",                 "min_tier": "weak_inferred" }
  ],
  "scope": { "common_ancestor": "mcp", "max_depth": 4 },
  "constraints": { "within_seconds": 300, "min_confidence": 0.7 },
  "attack": ["T1059", "T1555"]
}
