{
  "id": "maccrab_ai_agent_credential_network_persistence",
  "title": "AI agent + credential access + network + persistence",
  "severity": "high",
  "type": "graph",
  "nodes": {
    "agent": { "type": "ai_agent" },
    "proc": {
      "type": "process",
      "where": {
        "executable_name": { "in": ["zsh", "bash", "sh", "python", "python3", "node", "osascript"] }
      }
    },
    "cred":    { "type": "file",        "where": { "file_kind":   { "equals": "credential_file" } } },
    "net":     { "type": "network",     "where": { "reputation":  { "not_in": ["known_good", "private_range"] } } },
    "persist": { "type": "persistence" }
  },
  "edges": [
    { "from": "agent", "to": "proc",    "relation": "associated_with_agent", "min_tier": "strong_inferred" },
    { "from": "proc",  "to": "cred",    "relation": "read",                  "min_tier": "weak_inferred" },
    { "from": "proc",  "to": "net",     "relation": "connected_to",          "min_tier": "weak_inferred" },
    { "from": "proc",  "to": "persist", "relation": "created_persistence",   "min_tier": "strong_inferred" }
  ],
  "scope": { "common_ancestor": "proc", "max_depth": 4 },
  "constraints": { "within_seconds": 300, "min_confidence": 0.75 },
  "attack": ["T1059", "T1555", "T1543.001", "T1105"]
}
