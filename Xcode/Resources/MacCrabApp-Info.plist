	<key>NSFullDiskAccessUsageDescription</key>
	<string>MacCrab needs Full Disk Access so the detection engine can read TCC state, observe access to protected paths, and detect tamper attempts against its own configuration.</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 CaddyLabs. MacCrab is distributed under the Apache 2.0 License.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>MacCrab inspects local network connections made by running processes to surface suspicious outbound patterns. Metadata stays on-device.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>MacCrab monitors for ultrasonic voice-injection attacks (DolphinAttack / NUIT). Audio is processed on-device and never leaves your Mac.</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSSystemExtensionUsageDescription</key>
	<string>MacCrab uses an Endpoint Security system extension to detect threats in real time. The extension runs at the kernel event boundary and observes process, file, and network activity on your Mac.</string>
	<!-- Sparkle auto-update keys. SUPublicEDKey is the EdDSA verification
	     key for signed appcast entries; losing the matching private key
	     bricks the update channel for every existing install. -->
	<key>SUFeedURL</key>
	<string>https://maccrab.com/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>de+dzPjBve7LP5qxoE7nR6shThsjubkVasi+i8ehT4E=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
	<key>SUAutomaticallyUpdate</key>
	<false/>
</dict>
