*.xccheckout

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
*.swp
*.swo
*~

# Compiled detection rules (generated output -- do not commit)
compiled_rules/

# Runtime data (generated by hawkeyed -- do not commit)
baseline.json
baseline_config.json
alerts.jsonl
events.jsonl

# SQLite databases (runtime state, not source)
*.db
*.db-shm
*.db-wal

# Entitlements for local dev signing (may contain team-specific info)
*.entitlements

# Code signing artifacts
*.mobileprovision
*.provisionprofile

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# IDE and editor files
.idea/
.vscode/
*.code-workspace
